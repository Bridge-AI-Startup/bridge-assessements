# MongoDB Atlas Connection String
ATLAS_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# Database Name
DB_NAME=bridge-assessments

# Server Port
PORT=5050

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Optional: base URL for candidate share links (generate-link, invites, competition join).
# In production, defaults to https://app.bridge-jobs.com if unset. Use for staging or custom hosts.
# SHARE_LINK_BASE_URL=https://app.bridge-jobs.com

# Hackathon default slug for /HackathonDashboard (no ?slug=): stored on this user's MongoDB document (hackathonDefaultSlug).
# Only this email may PATCH /api/users/hackathon-default-slug. Optional server fallback if unset: HACKATHON_DEFAULT_SLUG.
# HACKATHON_ADMIN_EMAIL=saaz.m@icloud.com
# HACKATHON_DEFAULT_SLUG=the-challenge

# Optional: block POST /api/competitions/:slug/join before this instant (ISO 8601 UTC).
# Use the same value as client VITE_HACKATHON_RELEASE_AT so API matches the countdown.
# COMPETITION_JOIN_EARLIEST_AT=2026-04-18T12:00:00.000Z

# Node Environment
NODE_ENV=development

# Firebase Admin SDK
# REQUIRED for production (e.g., Render): Service account JSON as string
# Paste the entire JSON content from Firebase Console as a single-line string
# In Render, set this as an environment variable (newlines will be escaped automatically)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Optional for local development only: Path to service account JSON file
# This method does NOT work in production environments like Render
# FIREBASE_SERVICE_ACCOUNT_PATH=./path/to/serviceAccountKey.json

# Agent Tools Secret (for ElevenLabs agent tool authentication)
# Required for /api/agent-tools/* endpoints
# If not set, access is allowed without auth (development only)
# AGENT_SECRET=your-secret-token-here

# ElevenLabs Webhook Secret (for post-call webhook signature verification)
# Required for /webhooks/elevenlabs endpoint
# Get this from ElevenLabs Agents Platform settings when configuring webhooks
# ELEVENLABS_WEBHOOK_SECRET=your-webhook-secret-here

# Pinecone Configuration
# Required for code indexing and retrieval
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=your-pinecone-index-name

# E2B (optional) — isolated sandboxes for grading / running candidate code
# https://e2b.dev/dashboard?tab=keys
# E2B_API_KEY=e2b_***
# graderSandbox runCommand defaults both timeoutMs and requestTimeoutMs to 0 (E2B: no deadline). The SDK otherwise defaults each to 60s; long npm installs hit deadline_exceeded on the gRPC stream before the command “timeout”.
# Optional local dir for behavioral-grading artifacts (logs/screenshots)
# GRADING_STORAGE_DIR=./storage/grading
# Local storage directory for candidate uploaded submission archives (default: ./storage/submissions)
# SUBMISSION_UPLOAD_STORAGE_DIR=./storage/submissions
# Submission source mode: both | github | upload (default: both)
# SUBMISSION_SOURCE_MODE=both
# Max upload size in bytes for /api/submissions/token/:token/upload (default: 524288000 = 500MB)
# SUBMISSION_UPLOAD_MAX_BYTES=524288000
# Max extracted bytes when unzipping uploaded archives for indexing/execution (default: 314572800 = 300MB)
# SUBMISSION_UPLOAD_MAX_EXTRACTED_BYTES=314572800
# Max extracted file count when unzipping uploaded archives (default: 20000)
# SUBMISSION_UPLOAD_MAX_EXTRACTED_FILES=20000
# Master switch for E2B behavioral grading (auto on submit + POST …/grade-behavioral). Default when unset: disabled.
# BEHAVIORAL_GRADING_ENABLED=false
# Optional concurrency cap for post-submit behavioral grading workers (default: 2)
# BEHAVIORAL_GRADING_MAX_CONCURRENT=2
# E2B sandbox max lifetime for one behavioral grading run in ms (default: 1800000 = 30 min). Increase if grading hits sandbox timeout with many checks.
# BEHAVIORAL_GRADING_SANDBOX_TIMEOUT_MS=1800000
# Enable behavioral grading for upload-based submissions (default: true)
# BEHAVIORAL_GRADING_UPLOAD_ENABLED=true
# Log [behavioral …] milestones to stdout (default on). Set to 0 to silence.
# BEHAVIORAL_GRADING_LOG=0
# Behavioral judge browser tools need Playwright Chromium on this machine: from server/ run `npm run playwright:install` (also runs via npm postinstall).
# If you cannot install browsers, disable browser_* tools and rely on CLI + seed HTTP text: BEHAVIORAL_SKIP_BROWSER=1
# AI Provider Configuration (using LangChain)
# Global default provider for all use cases (can be overridden per use case)
# Options: "openai", "anthropic", or "gemini" (default: "openai")
AI_PROVIDER=openai

# Per-Use-Case Provider Configuration
# Override the global provider for specific use cases:
# - AI_PROVIDER_ASSESSMENT_GENERATION: Generate assessment components from job description
# - AI_PROVIDER_ASSESSMENT_CHAT: Chat with assessment AI assistant
# - AI_PROVIDER_INTERVIEW_QUESTIONS: Generate interview questions from code
# - AI_PROVIDER_INTERVIEW_SUMMARY: Generate interview summary from transcript
# Example: AI_PROVIDER_ASSESSMENT_GENERATION=anthropic
# Example: AI_PROVIDER_INTERVIEW_QUESTIONS=gemini

# OpenAI Configuration
# Required when using OpenAI (globally or for specific use cases)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
# Vision model for proctoring transcript generation (default: gpt-4o)
# gpt-4o is recommended for accurate text/code OCR from screenshots
# gpt-4o-mini is cheaper but significantly less accurate at reading screen text
OPENAI_VISION_MODEL=gpt-4o
# Max concurrent OpenAI requests (e.g. vision) — default 2. Set >= TRANSCRIPT_BATCH_CONCURRENCY to speed up transcript generation.
# OPENAI_MAX_CONCURRENT=4
# Per-use-case OpenAI models (optional):
# OPENAI_MODEL_ASSESSMENT_GENERATION=gpt-4o
# OPENAI_MODEL_ASSESSMENT_CHAT=gpt-4o-mini
# OPENAI_MODEL_INTERVIEW_QUESTIONS=gpt-4o
# OPENAI_MODEL_INTERVIEW_SUMMARY=gpt-4o-mini

# Anthropic Configuration
# Required when using Anthropic (globally or for specific use cases)
ANTHROPIC_API_KEY=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
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# Per-use-case Anthropic models (optional):
# ANTHROPIC_MODEL_ASSESSMENT_GENERATION=claude-3-5-sonnet-20241022
# ANTHROPIC_MODEL_ASSESSMENT_CHAT=claude-3-5-haiku-20241022
# ANTHROPIC_MODEL_INTERVIEW_QUESTIONS=claude-3-5-sonnet-20241022
# ANTHROPIC_MODEL_INTERVIEW_SUMMARY=claude-3-5-haiku-20241022

# Gemini Configuration
# Required when using Gemini (globally or for specific use cases)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-pro
# Per-use-case Gemini models (optional):
# GEMINI_MODEL_ASSESSMENT_GENERATION=gemini-1.5-pro
# GEMINI_MODEL_ASSESSMENT_CHAT=gemini-1.5-flash
# GEMINI_MODEL_INTERVIEW_QUESTIONS=gemini-1.5-pro
# GEMINI_MODEL_INTERVIEW_SUMMARY=gemini-1.5-flash

# Stripe Configuration
# Required for subscription billing
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_ID=price_your_price_id_here
APP_URL=http://localhost:5173

# LLM Proxy Configuration
# Maximum cost allowed per submission (in USD)
LLM_PROXY_MAX_COST=10.00
# Maximum time allowed per submission (in milliseconds, default: 1 hour)
LLM_PROXY_MAX_TIME=3600000
# Require LLM trace upload before submission (default: true)
REQUIRE_LLM_TRACE=true

# Task Execution Configuration
# Timeout for task execution (in milliseconds, default: 30 seconds)
TASK_EXECUTION_TIMEOUT=30000
# Maximum concurrent task executions (default: 5)
TASK_MAX_CONCURRENT=5

# Proctoring / Screen Capture Configuration
# Local storage directory for captured frames and transcripts (default: ./storage/proctoring).
# Used when PROCTORING_STORAGE_BACKEND is unset or "local" (default).
PROCTORING_STORAGE_DIR=./storage/proctoring
# Object storage backend: omit or "local" = filesystem under PROCTORING_STORAGE_DIR; "s3" = Amazon S3.
# If PROCTORING_S3_BUCKET (or AWS_S3_BUCKET) is set, S3 is used even when this is unset.
# PROCTORING_STORAGE_BACKEND=s3
# S3 bucket name (required for S3). Object keys match local paths, e.g. {sessionId}/frames/....png
# PROCTORING_S3_BUCKET=your-proctoring-bucket
# Optional alias for the bucket name
# AWS_S3_BUCKET=your-proctoring-bucket
# AWS region for the bucket (required for S3)
# AWS_REGION=us-east-1
# Credentials: use IAM user keys on Render (standard AWS env vars). Omit locally if using AWS_PROFILE / SSO.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# One-time copy from local disk to S3 (run from a machine with both paths and AWS creds):
# npx tsx src/scripts/migrateProctoringLocalToS3.ts --dry-run
# npx tsx src/scripts/migrateProctoringLocalToS3.ts
# Enable/disable AI transcript generation (default: true)
TRANSCRIPT_GENERATION_ENABLED=true
# Frame capture interval in milliseconds (default: 5000 = 5 seconds)
PROCTORING_FRAME_INTERVAL_MS=5000
# Pixel diff threshold for client-side dedup (default: 0.03 = 3%)
PROCTORING_DEDUP_THRESHOLD=0.03

# ElevenLabs in-session companion (CandidateAssessment notch): when true, agent speaks only the opening line, then the client disconnects ElevenLabs and records the mic as WebM chunks (companion/voice). Omit or false = full interactive companion.
# COMPANION_VOICE_LISTEN_ONLY=true

# Prompt-only transcript: frames per batch (default: 2; 3–4 = fewer API calls, more tokens per request)
# TRANSCRIPT_BATCH_SIZE=2
# Prompt-only: max batches processed in parallel (default: 2). Set OPENAI_MAX_CONCURRENT >= this to avoid queuing.
# TRANSCRIPT_BATCH_CONCURRENCY=2
# Transcript region batching: max crops per region type before flush (default: 5; higher = fewer API calls)
# TRANSCRIPT_REGION_BATCH_SIZE=5
# Layout re-detect interval: re-run region detection every N frames (default: 90; higher = fewer layout calls)
# TRANSCRIPT_LAYOUT_REDETECT_INTERVAL=90
# Layout image max dimension: downscale frame to this for layout detection only (default: 1280; fewer tokens)
# TRANSCRIPT_LAYOUT_MAX_PIXELS=1280
# Transcript OCR cache: reuse cached OCR for file_tree/terminal when thumb diff below threshold (default: 0.6 = 60%)
TRANSCRIPT_OCR_CACHE_CHANGE_THRESHOLD=0.6
# Debug: save 64x64 cached region thumbnails to disk for verification (default: false)
# TRANSCRIPT_DEBUG_SAVE_CACHE_THUMBS=true
# Directory for debug thumbs (default: {PROCTORING_STORAGE_DIR}/ocr-cache-thumbs)
# TRANSCRIPT_DEBUG_CACHE_THUMBS_DIR=./storage/proctoring/ocr-cache-thumbs

# Sliding-window incremental transcript: run transcript generation for active sessions on an interval.
# When enabled, transcript is built during the assessment so submit only finalizes (no full re-run). Recommended for production.
# TRANSCRIPT_INCREMENTAL_ENABLED=true
# Interval in milliseconds (default: 60000 = 1 minute)
# TRANSCRIPT_INCREMENTAL_INTERVAL_MS=60000

