  "scripts": {
    "build": "echo 'No build step required - using tsx to run TypeScript directly'",
    "start": "tsx src/server.ts",
    "dev": "nodemon --env-file=config.env --exec tsx src/server.ts",
    "e2b-smoke": "tsx src/scripts/e2b-smoke.ts",
    "behavioral-grading-smoke": "tsx src/scripts/behavioral-grading-smoke.ts",
    "playwright:install": "playwright install chromium",
    "test": "echo \"Error: no test specified\" && exit 1",
    "postinstall": "npx playwright install chromium"
  },
